# AI Job Agent — Environment Variables
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=aijobagent
DB_ROOT_PASSWORD=change_me_root_password
DB_USERNAME=aijobagent
DB_PASSWORD=change_me_db_password

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── RabbitMQ ──────────────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# ── JWT ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=replace_with_at_least_256_bit_base64_encoded_secret

# ── AI / OpenAI ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-replace-with-your-openai-api-key
AI_BASE_URL=https://api.openai.com/v1
AI_ANALYSIS_MODEL=gpt-4o-mini
AI_TAILOR_MODEL=gpt-4o

# ── Email / SMTP ──────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
# Use a Gmail App Password (not your account password)
MAIL_PASSWORD=your_gmail_app_password
NOTIFICATION_FROM_EMAIL=noreply@aijobagent.dev

# ── Scheduler Cron Expressions ────────────────────────────────────────
SCRAPE_CRON=0 0 6 * * *
DAILY_DIGEST_CRON=0 0 7 * * *

# ── File Storage ─────────────────────────────────────────────────────
RESUME_UPLOAD_DIR=/app/storage/resumes
PDF_OUTPUT_DIR=/app/storage/pdfs

# ── Frontend ─────────────────────────────────────────────────────────
# In Docker mode, point to the nginx proxy (port 80)
VITE_API_BASE_URL=http://localhost

# ── Feature Flags ────────────────────────────────────────────────────
SWAGGER_ENABLED=false
